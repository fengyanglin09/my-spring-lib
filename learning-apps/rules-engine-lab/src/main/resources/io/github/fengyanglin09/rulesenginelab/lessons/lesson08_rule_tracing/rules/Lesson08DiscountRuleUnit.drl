package io.github.fengyanglin09.rulesenginelab.lessons.lesson08_rule_tracing.rules;

unit Lesson08DiscountRuleUnit;

rule "Missing customer type"
    salience 100
when
    $request : /requests[
        customerType == null || customerType.trim().isEmpty()
    ]
    $result : /results[ valid == true ]
then
    modify($result) {
        setValid(false),
        setReason("Invalid request"),
        addValidationError("customerType is required")
    }
end

rule "Missing order amount"
    salience 100
when
    $request : /requests[ orderAmount == null ]
    $result : /results[ valid == true ]
then
    modify($result) {
        setValid(false),
        setReason("Invalid request"),
        addValidationError("orderAmount is required")
    }
end

rule "Negative order amount"
    salience 100
when
    $request : /requests[
        orderAmount != null,
        orderAmount.compareTo(java.math.BigDecimal.ZERO) < 0
    ]
    $result : /results[ valid == true ]
then
    modify($result) {
        setValid(false),
        setReason("Invalid request"),
        addValidationError("orderAmount must not be negative")
    }
end

rule "Large order discount"
    /*
     * Notice this rule does not call addFiredRule(...).
     *
     * Lesson 08 records matched and fired rules through an AgendaEventListener,
     * outside the DRL business action.
     */
    activation-group "discount-winner"
    salience 30
when
    $config : /configs
    $request : /requests[
        orderAmount != null,
        orderAmount.compareTo($config.getLargeOrderMinimumAmount()) > 0
    ]
    $result : /results[ valid == true, reason == null ]
then
    modify($result) {
        setDiscountPercent($config.getLargeOrderPercent()),
        setReason("Large order")
    }
end

rule "VIP discount"
    activation-group "discount-winner"
    salience 20
when
    $config : /configs
    $request : /requests[
        customerType == "VIP",
        orderAmount != null,
        orderAmount.compareTo($config.getVipMinimumAmount()) > 0
    ]
    $result : /results[ valid == true, reason == null ]
then
    modify($result) {
        setDiscountPercent($config.getVipPercent()),
        setReason("VIP customer")
    }
end

rule "Normal customer discount"
    activation-group "discount-winner"
    salience 10
when
    $config : /configs
    $request : /requests[
        customerType == "NORMAL",
        orderAmount != null,
        orderAmount.compareTo($config.getNormalMinimumAmount()) > 0
    ]
    $result : /results[ valid == true, reason == null ]
then
    modify($result) {
        setDiscountPercent($config.getNormalPercent()),
        setReason("Normal customer")
    }
end
