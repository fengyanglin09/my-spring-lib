package io.github.fengyanglin09.rulesenginelab.lessons.lesson11_candidate_facts.rules;

unit Lesson11DiscountRuleUnit;

import io.github.fengyanglin09.rulesenginelab.lessons.lesson11_candidate_facts.model.Lesson11DiscountCandidate;
import io.github.fengyanglin09.rulesenginelab.lessons.lesson11_candidate_facts.model.Lesson11RulePhase;

rule "Missing customer type"
when
    $context : /contexts[ phase == Lesson11RulePhase.VALIDATION ]
    $request : /requests[
        customerType == null || customerType.trim().isEmpty()
    ]
    $result : /results[ valid == true ]
then
    modify($result) {
        setValid(false),
        setReason("Invalid request"),
        addValidationError("customerType is required")
    }
end

rule "Missing order amount"
when
    $context : /contexts[ phase == Lesson11RulePhase.VALIDATION ]
    $request : /requests[ orderAmount == null ]
    $result : /results[ valid == true ]
then
    modify($result) {
        setValid(false),
        setReason("Invalid request"),
        addValidationError("orderAmount is required")
    }
end

rule "Large order candidate"
    /*
     * Candidate rules do not modify the final result.
     *
     * They create possible discount facts. Multiple candidate rules can fire
     * for the same request, which is exactly what we want in this lesson.
     *
     * Notice the direction:
     *   Java service adds request/result/config/context before firing rules.
     *   This DRL rule adds candidate facts after its conditions match.
     */
when
    $context : /contexts[ phase == Lesson11RulePhase.DISCOUNT ]
    $config : /configs
    $request : /requests[
        orderAmount != null,
        orderAmount.compareTo($config.getLargeOrderMinimumAmount()) > 0
    ]
    $result : /results[ valid == true ]
then
    // This is a rule-created fact. It did not exist before this rule fired.
    candidates.add(new Lesson11DiscountCandidate(
        "Large order candidate",
        $config.getLargeOrderPercent(),
        "Large order"
    ));
end

rule "VIP candidate"
when
    $context : /contexts[ phase == Lesson11RulePhase.DISCOUNT ]
    $config : /configs
    $request : /requests[
        customerType == "VIP",
        orderAmount != null,
        orderAmount.compareTo($config.getVipMinimumAmount()) > 0
    ]
    $result : /results[ valid == true ]
then
    // Another rule-created fact. The service will query it after firing.
    candidates.add(new Lesson11DiscountCandidate(
        "VIP candidate",
        $config.getVipPercent(),
        "VIP customer"
    ));
end

rule "Normal customer candidate"
when
    $context : /contexts[ phase == Lesson11RulePhase.DISCOUNT ]
    $config : /configs
    $request : /requests[
        customerType == "NORMAL",
        orderAmount != null,
        orderAmount.compareTo($config.getNormalMinimumAmount()) > 0
    ]
    $result : /results[ valid == true ]
then
    // Another rule-created fact. No final winner is selected in Lesson 11.
    candidates.add(new Lesson11DiscountCandidate(
        "Normal customer candidate",
        $config.getNormalPercent(),
        "Normal customer"
    ));
end

/*
 * Query candidate facts after rules have created them.
 *
 * If no candidate rule fired, /candidates is empty and this query returns no
 * rows.
 */
query "Find all discount candidates"
    $candidate : /candidates
end
